generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("producer") // admin, producer
  plan          String   @default("free")
  avatar        String?
  bio           String?
  verified      Boolean  @default(false)
  verifyToken   String?
  resetToken    String?
  resetExpiry   DateTime?
  stripeCustomerId String?
  stripeSubId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  suspended     Boolean  @default(false)

  beats            Beat[]
  orders           Order[]
  payouts          Payout[]
  licenses         License[]
  sessions         Session[]
  notifications    Notification[]
  supportTickets   SupportTicket[]
  analytics        AnalyticsEvent[]
  collabBeats      BeatCollaborator[] @relation("CollabProducer")
  beatRequests     BeatRequest[]      @relation("BeatRequests")
  beatRequestBids  BeatRequestBid[]   @relation("BeatRequestBids")
  royaltyReports   RoyaltyReport[]    @relation("RoyaltyReportBuyer")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Beat {
  id          String   @id @default(cuid())
  title       String
  producerId  String
  genre       String
  bpm         Int
  key         String
  mood        String?
  tags        String   @default("[]")
  description String?
  audioFile   String?
  artwork     String?
  waveform    String?
  priceBasic      Float @default(29.99)
  pricePremium    Float @default(99.99)
  priceExclusive  Float @default(299.99)
  plays       Int      @default(0)
  status      String   @default("active")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  producer        User               @relation(fields: [producerId], references: [id])
  licenses        License[]
  analytics       AnalyticsEvent[]
  stems           BeatStem[]
  collaborators   BeatCollaborator[]
  royaltyReports  RoyaltyReport[]
}

model BeatStem {
  id        String   @id @default(cuid())
  beatId    String
  beat      Beat     @relation(fields: [beatId], references: [id], onDelete: Cascade)
  type      String   // drums, bass, melody, other
  filePath  String?
  status    String   @default("pending") // pending, processing, ready, failed
  createdAt DateTime @default(now())

  @@unique([beatId, type])
}

model BeatCollaborator {
  id         String   @id @default(cuid())
  beatId     String
  beat       Beat     @relation(fields: [beatId], references: [id], onDelete: Cascade)
  producerId String
  producer   User     @relation("CollabProducer", fields: [producerId], references: [id])
  split      Float    // percentage 0-100
  role       String?  // co-producer, mixing, mastering, etc.
  createdAt  DateTime @default(now())

  @@unique([beatId, producerId])
}

model BeatRequest {
  id          String           @id @default(cuid())
  artistId    String
  artist      User             @relation("BeatRequests", fields: [artistId], references: [id])
  title       String
  description String
  genre       String?
  bpm         String?
  mood        String?
  budget      Float
  deadline    DateTime?
  status      String           @default("open") // open, closed, completed, cancelled
  bids        BeatRequestBid[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model BeatRequestBid {
  id         String      @id @default(cuid())
  requestId  String
  request    BeatRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  producerId String
  producer   User        @relation("BeatRequestBids", fields: [producerId], references: [id])
  message    String
  audioDemo  String?
  price      Float
  status     String      @default("pending") // pending, accepted, rejected
  createdAt  DateTime    @default(now())
}

model License {
  id          String   @id @default(cuid())
  beatId      String
  buyerId     String
  type        String
  price       Float
  terms       String?
  downloadUrl String?
  stripePaymentId String?
  createdAt   DateTime @default(now())

  beat           Beat            @relation(fields: [beatId], references: [id])
  buyer          User            @relation(fields: [buyerId], references: [id])
  royaltyReports RoyaltyReport[]
}

model MerchProduct {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  price       Float
  images      String   @default("[]")
  sizes       String   @default("[]")
  colors      String   @default("[]")
  printfulId  String?
  stock       Int      @default(999)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  status          String   @default("pending")
  total           Float
  shippingAddress String
  stripePaymentId String?
  printfulOrderId String?
  trackingNumber  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User       @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  size        String?
  color       String?
  price       Float

  order       Order        @relation(fields: [orderId], references: [id])
  product     MerchProduct @relation(fields: [productId], references: [id])
}

model Payout {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  status      String   @default("pending")
  method      String   @default("stripe")
  stripeTransferId String?
  note        String?
  requestedAt DateTime @default(now())
  processedAt DateTime?

  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id         String   @id @default(cuid())
  userId     String
  subject    String
  message    String
  status     String   @default("open")
  priority   String   @default("medium")
  response   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  beatId    String?
  type      String
  platform  String?
  country   String?
  metadata  String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  beat      Beat?    @relation(fields: [beatId], references: [id])
}

model RoyaltyReport {
  id         String   @id @default(cuid())
  beatId     String
  licenseId  String
  buyerId    String
  platform   String   // spotify, apple_music, youtube, soundcloud, etc.
  trackTitle String
  trackUrl   String?
  streams    Int      @default(0)
  revenue    Float    @default(0)
  reportedAt DateTime @default(now())

  beat       Beat     @relation(fields: [beatId], references: [id])
  buyer      User     @relation("RoyaltyReportBuyer", fields: [buyerId], references: [id])
  license    License  @relation(fields: [licenseId], references: [id])
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float
  maxUses     Int?
  uses        Int      @default(0)
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}
